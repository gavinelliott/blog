---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { SEO } from 'astro-seo';

interface Props {
	title: string;
	description: string;
	image?: string;
	article?: boolean;
	publishDate?: Date;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { 
	title, 
	description, 
	image = '/images/writing-blog-post-placeholder.jpg',
	article = false,
	publishDate
} = Astro.props;

// Current URL for canonical links
const currentUrl = Astro.url.toString();
---

<!-- SEO Component -->
<SEO
  title={title}
  description={description}
  canonical={canonicalURL.toString()}
  openGraph={{
    basic: {
      title: title,
      type: article ? 'article' : 'website',
      image: new URL(image, Astro.url).toString(),
      url: currentUrl,
    },
    optional: {
      description: description,
      siteName: "Gavin Elliott",
      locale: "en_US",
    },
    image: {
      alt: `Image for ${title}`,
    },
    article: article ? {
      publishedTime: publishDate?.toISOString(),
      authors: ["Gavin Elliott"],
    } : undefined,
  }}
  twitter={{
    card: "summary_large_image",
    site: "@gavinelliott",
    creator: "@gavinelliott",
    title: title,
    description: description,
    image: new URL(image, Astro.url).toString(),
    imageAlt: `Image for ${title}`,
  }}
/>

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href="/favicon.ico" />
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" href="/favicon.png" />
<meta name="generator" content={Astro.generator} />

<!-- Accessibility Metadata -->
<meta name="color-scheme" content="light" />
<meta name="theme-color" content="#FFFFF8" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Lora:ital,wght@0,400;0,700;1,400&display=swap"
	rel="stylesheet"
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Performance hints for browser - prefetch on hover -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  // Prefetch pages on hover/focus for faster navigation
  const links = document.querySelectorAll('a');
  const prefetched = new Set();
  
  links.forEach(link => {
    if (link.hostname === window.location.hostname) {
      link.addEventListener('mouseenter', () => {
        const href = link.getAttribute('href');
        
        if (href && !prefetched.has(href)) {
          const linkEl = document.createElement('link');
          linkEl.rel = 'prefetch';
          linkEl.href = href;
          document.head.appendChild(linkEl);
          prefetched.add(href);
        }
      });
    }
  });
});
</script>

<!-- Service worker registration -->
<script>
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('/sw.js')
      .then(registration => {
        console.log('Service Worker registered with scope:', registration.scope);
      })
      .catch(error => {
        console.error('Service Worker registration failed:', error);
      });
  });
}
</script>
