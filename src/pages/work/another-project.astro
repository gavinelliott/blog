---
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';

// Metadata for the page
const title = "Another Project | Case Study | Gavin Elliott";
const description = "A detailed case study of Another Project, showcasing the process, challenges, and solutions.";
---

<CaseStudyLayout title={title} description={description} noIndex={true}>
	<article class="case-study">
		<div class="case-study-header">
			<h1>Another Project</h1>
			<div class="case-study-metadata">
				<div class="project-date">2022</div>
				<div class="project-categories">UX Research, Service Design, Strategy</div>
			</div>
		</div>
		
		<div class="case-study-hero">
			<div class="hero-placeholder"></div>
		</div>
		
		<div class="case-study-content">
			<p>This is a placeholder for another case study. The content will be added later.</p>
			
			<section class="next-case-study">
				<h2>Next Case Study</h2>
				<a href="/work/project-example" class="next-project-link" tabindex="0" aria-label="View Project Example case study">
					<span class="next-project-title">Project Example</span>
					<span class="next-project-arrow">→</span>
				</a>
			</section>
		</div>
	</article>
</CaseStudyLayout>

<style>
	.case-study {
		width: 100%;
		margin: 0 auto;
	}
	
	.case-study-header {
		text-align: center;
		margin-bottom: 3rem;
	}
	
	.case-study-header h1 {
		font-family: "franklin-gothic-urw-comp", sans-serif;
		font-weight: 600;
		font-size: 3.5rem;
		margin-bottom: 1rem;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: #051005;
		line-height: 1.1;
	}
	
	.case-study-metadata {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 2rem;
		font-family: "linotype-sabon", sans-serif;
		font-size: 1.2rem;
		color: rgba(5, 16, 5, 0.8);
	}
	
	.case-study-hero {
		margin-bottom: 4rem;
		width: 100%;
	}
	
	.hero-placeholder {
		width: 100%;
		height: 500px;
		background-color: #90B090;
		opacity: 0.8;
		border-radius: 8px;
	}
	
	.case-study-content {
		max-width: 900px;
		margin: 0 auto;
		padding: 0 1rem;
		font-family: "linotype-sabon", sans-serif;
		font-size: 1.25rem;
		line-height: 1.6;
		color: rgba(5, 16, 5, 0.9);
	}
	
	.next-case-study {
		margin: 5rem 0 2rem;
		text-align: center;
	}
	
	.next-project-link {
		display: inline-flex;
		align-items: center;
		gap: 1rem;
		font-family: "franklin-gothic-urw-comp", sans-serif;
		font-weight: 600;
		font-size: 1.75rem;
		color: #051005;
		text-decoration: none;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		transition: transform 0.3s ease;
		padding: 0.5rem 1rem;
	}
	
	.next-project-link:hover,
	.next-project-link:focus {
		transform: translateX(10px);
		outline: none;
	}
	
	.next-project-link:focus-visible {
		outline: 2px solid #90B090;
		outline-offset: 4px;
	}
	
	.next-project-arrow {
		font-size: 1.5rem;
	}
	
	@media (max-width: 768px) {
		.hero-placeholder {
			height: 300px;
		}
		
		.case-study-header h1 {
			font-size: 2.75rem;
		}
		
		.case-study-content {
			font-size: 1.2rem;
		}
	}
	
	@media (max-width: 480px) {
		.case-study-header h1 {
			font-size: 2.25rem;
		}
		
		.case-study-metadata {
			gap: 1rem;
			font-size: 1.1rem;
		}
		
		.hero-placeholder {
			height: 200px;
		}
		
		.case-study-content {
			font-size: 1.1rem;
		}
		
		.next-project-link {
			font-size: 1.5rem;
		}
	}
</style> 